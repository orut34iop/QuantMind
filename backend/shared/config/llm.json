{
  "providers": {
    "deepseek": {
      "enabled": true,
      "api_key": "${DEEPSEEK_API_KEY}",
      "base_url": "https://api.deepseek.com",
      "models": {
        "deepseek-chat": {
          "max_tokens": 4000,
          "temperature": 0.7,
          "timeout": 60
        }
      }
    },
    "openai": {
      "enabled": false,
      "api_key": "${OPENAI_API_KEY}",
      "base_url": "https://api.openai.com",
      "models": {
        "gpt-3.5-turbo": {
          "max_tokens": 4000,
          "temperature": 0.7,
          "timeout": 60
        },
        "gpt-4": {
          "max_tokens": 4000,
          "temperature": 0.7,
          "timeout": 60
        }
      }
    }
  },
  "default_provider": "deepseek",
  "fallback_providers": [
    "openai"
  ],
  "usage_tracking": {
    "enabled": true,
    "log_requests": true,
    "log_responses": false
  }
}
