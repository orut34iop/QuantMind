# QuantMind OSS 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# OSS 部署使用相对路径，通过 Nginx/反向代理访问
# 前端会自动使用当前域名作为 API 基地址
# VITE_API_BASE_URL=
# VITE_USER_API_URL=
# VITE_WS_BASE_URL=

# 云端部署配置（取消注释以启用）
# VITE_API_BASE_URL=https://api.quantmind.cloud
# VITE_USER_API_URL=https://api.quantmind.cloud/api/v1
# VITE_WS_BASE_URL=wss://api.quantmind.cloud/api/v1/ws/market
