{
  "name": "QuantMind",
  "private": true,
  "version": "0.1.0",
  "description": "QuantMind 智能控制中心桌面端 (Electron + React + Vite)",
  "main": "electron/main.js",
  "type": "commonjs",
  "author": "",
  "scripts": {
    "dev": "concurrently \"npm:dev:react\" \"npm:dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "wait-on tcp:3000 && cross-env VITE_DEV=1 electron .",
    "dev:simple": "node scripts/electron-dev.js",
    "build": "npm run build:react && npm run build:electron",
    "build:react": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:package": "npm run build && electron-builder --publish=never",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "preview": "vite preview",
    "start": "electron ."
  },
  "build": {
    "appId": "com.quantmind.dashboard",
    "productName": "QuantMind Dashboard",
    "files": [
      "dist-react/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.finance"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.90.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/lodash": "^4.17.4",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "axios": "^1.7.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "date-fns": "^3.6.0",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "framer-motion": "^11.2.10",
    "fuse.js": "^7.1.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.390.0",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "@tiptap/extension-character-count": "^2.6.6",
    "@tiptap/extension-image": "^2.6.6",
    "@tiptap/extension-link": "^2.6.6",
    "@tiptap/extension-placeholder": "^2.6.6",
    "@tiptap/extension-underline": "^2.6.6",
    "@tiptap/react": "^2.6.6",
    "@tiptap/starter-kit": "^2.6.6",
    "monaco-editor": "^0.55.1",
    "postcss": "^8.4.38",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.1.2",
    "react-router-dom": "^7.9.4",
    "recharts": "^2.12.7",
    "recoil": "^0.7.7",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.7",
    "tailwind-merge": "^2.3.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "typescript": "^5.4.5",
    "vite": "^7.2.4",
    "vitest": "^4.0.14",
    "wait-on": "^7.2.0",
    "@reduxjs/toolkit": "^2.2.5"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.6.2",
    "@types/prismjs": "^1.26.5",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "@vitest/coverage-v8": "^4.0.14",
    "@vitest/ui": "^4.0.14",
    "electron": "^39.2.3",
    "electron-builder": "^24.13.3",
    "electron-vite": "^4.0.1",
    "jsdom": "^24.1.0"
  }
}